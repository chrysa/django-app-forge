# syntax=docker/dockerfile:1
# Test image — runs the full suite with coverage gate (CI parity).
# Built and run by `make docker-test`.
#
# chrysa-codegen (chrysa-lib#113, lot L1) is pulled as a real git-ref dependency
# declared in pyproject.toml; `git` is required for the git+https install.
# chrysa-lib is private, so the fetch needs a credential — see the secret-mount
# stanza below (chrysa-lib DECISIONS.md D-0004).
FROM python:3.14-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip setuptools>=70 wheel

COPY pyproject.toml README.md ./
COPY src/ ./src/
COPY tests/ ./tests/

# chrysa-codegen lives in the private chrysa-lib repo, so the git+https install needs a
# credential. Per chrysa-lib DECISIONS.md D-0004: mount a token as a BuildKit secret and
# rewrite the git URL for this single layer, then drop the gitconfig in the same RUN so the
# token never persists in an image layer (the secret mount itself is never written to a layer).
RUN --mount=type=secret,id=ghtoken,required=true \
    git config --global url."https://x-access-token:$(cat /run/secrets/ghtoken)@github.com/".insteadOf "https://github.com/" \
 && pip install --no-cache-dir -e ".[dev]" \
 && rm -f /root/.gitconfig

# pytest-cov (configured in pyproject addopts: --cov + --cov-fail-under=85)
# owns coverage; just add the XML report for SonarCloud.
CMD ["pytest", "--cov-report=xml"]
